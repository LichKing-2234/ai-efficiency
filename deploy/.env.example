# -----------------------------------------------------------------------------
# Image Configuration
# -----------------------------------------------------------------------------
AE_IMAGE_REPOSITORY=ghcr.io/ai-efficiency/ai-efficiency
AE_IMAGE_TAG=v0.1.0
AE_UPDATER_IMAGE_REPOSITORY=ghcr.io/ai-efficiency/ai-efficiency
AE_UPDATER_IMAGE_TAG=v0.1.0
COMPOSE_PROJECT_NAME=ai-efficiency

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
AE_SERVER_PORT=8081
AE_SERVER_MODE=release
AE_SERVER_FRONTEND_URL=http://localhost:8081

# -----------------------------------------------------------------------------
# Bundled PostgreSQL Configuration
# Used by deploy/docker-compose.yml
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=ai_efficiency

# -----------------------------------------------------------------------------
# Bundled Redis Configuration
# Used by deploy/docker-compose.yml
# -----------------------------------------------------------------------------
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# External Infra Configuration
# Used by deploy/docker-compose.external.yml
# -----------------------------------------------------------------------------
AE_DB_DSN=postgres://postgres:postgres@postgres:5432/ai_efficiency?sslmode=disable
AE_REDIS_ADDR=redis:6379
AE_REDIS_PASSWORD=
AE_REDIS_DB=0

# -----------------------------------------------------------------------------
# Relay Configuration
# -----------------------------------------------------------------------------
AE_RELAY_URL=http://sub2api.example.com
AE_RELAY_API_KEY=
AE_RELAY_ADMIN_API_KEY=

# -----------------------------------------------------------------------------
# Security Configuration
# docker-deploy.sh will auto-generate these if they are blank.
# -----------------------------------------------------------------------------
AE_AUTH_JWT_SECRET=
AE_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Deployment Runtime
# -----------------------------------------------------------------------------
AE_DEPLOYMENT_MODE=bundled
AE_DEPLOYMENT_STATE_DIR=/var/lib/ai-efficiency
AE_DEPLOYMENT_UPDATE_ENABLED=true
AE_DEPLOYMENT_UPDATE_APPLY_ENABLED=true
AE_DEPLOYMENT_UPDATE_RELEASE_API_URL=https://api.github.com/repos/ai-efficiency/ai-efficiency/releases/latest
AE_DEPLOYMENT_UPDATE_UPDATER_URL=http://updater:8090

# -----------------------------------------------------------------------------
# Updater Sidecar
# -----------------------------------------------------------------------------
AE_UPDATER_ENV_FILE=/work/deploy/.env
AE_UPDATER_SERVICE_NAME=backend
# Optional override; if empty updater falls back to COMPOSE_PROJECT_NAME.
AE_UPDATER_PROJECT_NAME=
