# -----------------------------------------------------------------------------
# Operator Configuration
# -----------------------------------------------------------------------------
# This file intentionally contains only operator-facing values.
# Docker image/runtime defaults are provided in the compose files and docker-deploy.sh.

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
AE_SERVER_PORT=8081
AE_SERVER_FRONTEND_URL=http://localhost:8081

# -----------------------------------------------------------------------------
# Bundled PostgreSQL (used by deploy/docker-compose*.yml bundled stacks)
# docker-deploy.sh will auto-generate POSTGRES_PASSWORD if blank.
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=ai_efficiency

# -----------------------------------------------------------------------------
# Bundled Redis (used by deploy/docker-compose*.yml bundled stacks)
# -----------------------------------------------------------------------------
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# External Infra (used by deploy/docker-compose.external.yml)
# -----------------------------------------------------------------------------
AE_DB_DSN=postgres://postgres:postgres@postgres:5432/ai_efficiency?sslmode=disable
AE_REDIS_ADDR=redis:6379
AE_REDIS_PASSWORD=
AE_REDIS_DB=0

# -----------------------------------------------------------------------------
# Relay
# -----------------------------------------------------------------------------
AE_RELAY_URL=http://sub2api.example.com
AE_RELAY_API_KEY=
AE_RELAY_ADMIN_API_KEY=

# -----------------------------------------------------------------------------
# LDAP
# -----------------------------------------------------------------------------
AE_AUTH_LDAP_URL=
AE_AUTH_LDAP_BASE_DN=
AE_AUTH_LDAP_BIND_DN=
AE_AUTH_LDAP_BIND_PASSWORD=
AE_AUTH_LDAP_USER_FILTER=(uid=%s)
AE_AUTH_LDAP_TLS=false

# -----------------------------------------------------------------------------
# Security
# docker-deploy.sh will auto-generate these if they are blank.
# -----------------------------------------------------------------------------
AE_AUTH_JWT_SECRET=
AE_ENCRYPTION_KEY=
